+package com.example.notificationservice.service;
+
+import com.example.notificationservice.client.EmailSender;
+import com.example.notificationservice.client.SmsClient;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Service;
+
+@Slf4j
+@Service
+@RequiredArgsConstructor
+public class NotificationService {
+
+    private final EmailSender emailSender;
+    private final SmsClient smsClient;
+
+    // 동기 이메일 발송 — 요청 스레드를 블로킹
+    // Dead Letter Queue 없음 — 실패한 메시지는 유실됨
+    public void sendEmail(String to, String subject, String body) {
+        try {
+            emailSender.send(to, subject, body);
+            log.info("이메일 발송 완료: to={}", to);
+        } catch (Exception e) {
+            // catch(Exception) 포괄 처리 — 예외 유형 구분 없음
+            log.error("이메일 발송 실패", e);
+            // 재시도 없음, DLQ 없음 — 메시지 유실
+        }
+    }
+
+    // 동기 SMS 발송 — 요청 스레드를 블로킹
+    public void sendSms(String phone, String body) {
+        try {
+            smsClient.send(phone, body);
+            log.info("SMS 발송 완료: phone={}", phone);
+        } catch (Exception e) {
+            log.error("SMS 발송 실패", e);
+            // 재시도 없음, DLQ 없음
+        }
+    }
+}
