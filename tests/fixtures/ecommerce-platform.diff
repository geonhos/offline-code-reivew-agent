@@ -0,0 +1,58 @@
+package com.example.paymentservice.client;
+
+import org.springframework.stereotype.Component;
+
+import javax.net.ssl.*;
+import java.math.BigDecimal;
+import java.net.HttpURLConnection;
+import java.net.URL;
+import java.security.cert.X509Certificate;
+
+@Component
+public class PaymentGatewayClient {
+
+    private static final String GATEWAY_URL = "https://pg.example.com/api";
+
+    public void charge(String cardNumber, BigDecimal amount) {
+        try {
+            // TLS 인증서 검증 비활성화
+            TrustManager[] trustAllCerts = new TrustManager[]{
+                new X509TrustManager() {
+                    public X509Certificate[] getAcceptedIssuers() { return null; }
+                    public void checkClientTrusted(X509Certificate[] certs, String authType) {}
+                    public void checkServerTrusted(X509Certificate[] certs, String authType) {}
+                }
+            };
+
+            SSLContext sc = SSLContext.getInstance("SSL");
+            sc.init(null, trustAllCerts, new java.security.SecureRandom());
+            HttpsURLConnection.setDefaultSSLSocketFactory(sc.getSocketFactory());
+
+            // 타임아웃 미설정 — 외부 PG사 장애 시 무한 대기
+            URL url = new URL(GATEWAY_URL + "/charge");
+            HttpURLConnection conn = (HttpURLConnection) url.openConnection();
+            conn.setRequestMethod("POST");
+            conn.setDoOutput(true);
+
+            String body = String.format(
+                "{\"card\":\"%s\",\"amount\":%s}", cardNumber, amount
+            );
+            conn.getOutputStream().write(body.getBytes());
+
+            int responseCode = conn.getResponseCode();
+            if (responseCode != 200) {
+                throw new RuntimeException("PG 결제 실패: HTTP " + responseCode);
+            }
+        } catch (RuntimeException e) {
+            throw e;
+        } catch (Exception e) {
+            throw new RuntimeException("PG 통신 오류", e);
+        }
+    }
+
+    public void refund(String cardNumber, BigDecimal amount) {
+        try {
+            URL url = new URL(GATEWAY_URL + "/refund");
+            HttpURLConnection conn = (HttpURLConnection) url.openConnection();
+            conn.setRequestMethod("POST");
+            conn.setDoOutput(true);
+            String body = String.format(
+                "{\"card\":\"%s\",\"amount\":%s}", cardNumber, amount
+            );
+            conn.getOutputStream().write(body.getBytes());
+        } catch (Exception e) {
+            throw new RuntimeException("PG 환불 오류", e);
+        }
+    }
+}
