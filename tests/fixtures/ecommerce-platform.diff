+package com.example.orderservice.service;
+
+import com.example.orderservice.client.PaymentClient;
+import com.example.orderservice.client.ProductClient;
+import com.example.orderservice.domain.Order;
+import com.example.orderservice.domain.OrderRepository;
+import com.example.orderservice.domain.OrderStatus;
+import com.example.orderservice.dto.CreateOrderRequest;
+import lombok.RequiredArgsConstructor;
+import org.springframework.stereotype.Service;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.math.BigDecimal;
+import java.util.HashMap;
+import java.util.List;
+import java.util.Map;
+
+@Service
+@RequiredArgsConstructor
+public class OrderService {
+
+    private final OrderRepository orderRepository;
+    private final ProductClient productClient;
+    private final PaymentClient paymentClient;
+
+    // 분산 트랜잭션 미보장: 재고 차감 + 결제를 하나의 로컬 트랜잭션에서 처리
+    @Transactional
+    public Long createOrder(CreateOrderRequest request) {
+        Order order = Order.create(request.getUserId(), request.getAddress());
+
+        for (var item : request.getItems()) {
+            // 외부 서비스 호출이 트랜잭션 내에 있음
+            productClient.decreaseStock(item.getProductId(), item.getQuantity());
+            order.addItem(item.getProductId(), item.getProductName(),
+                item.getPrice(), item.getQuantity());
+        }
+
+        orderRepository.save(order);
+
+        // 결제도 트랜잭션 내 외부 호출
+        paymentClient.requestPayment(order.getId(), order.getTotalAmount());
+
+        return order.getId();
+    }
+
+    @Transactional
+    public void cancelOrder(Long orderId) {
+        Order order = orderRepository.findById(orderId)
+            .orElseThrow(() -> new RuntimeException("주문을 찾을 수 없습니다: " + orderId));
+        order.cancel();
+    }
+
+    @Transactional(readOnly = true)
+    public Order getOrder(Long orderId) {
+        return orderRepository.findById(orderId)
+            .orElseThrow(() -> new RuntimeException("주문을 찾을 수 없습니다: " + orderId));
+    }
+
+    // findAll() 후 메모리에서 필터링/집계
+    @Transactional(readOnly = true)
+    public Map<String, Object> getOrderStatistics() {
+        List<Order> allOrders = orderRepository.findAll();
+
+        Map<String, Object> stats = new HashMap<>();
+        stats.put("totalOrders", allOrders.size());
+        stats.put("totalRevenue", allOrders.stream()
+            .filter(o -> o.getStatus() != OrderStatus.CANCELLED)
+            .map(Order::getTotalAmount)
+            .reduce(BigDecimal.ZERO, BigDecimal::add));
+        stats.put("cancelledCount", allOrders.stream()
+            .filter(o -> o.getStatus() == OrderStatus.CANCELLED)
+            .count());
+
+        return stats;
+    }
+}
